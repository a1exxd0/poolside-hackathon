**/venv/
**/__pycache__/
.env
.envrc
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
# calibration artifacts
*.pt
*.calib
# model weights & fine-tuning checkpoints (multi-GB; base weights live in the
